{
  "buildCommand": "pnpm --filter @workspace/squadgod run build",
  "outputDirectory": "artifacts/squadgod/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "env": {
    "BASE_PATH": "/"
  },
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@5.1.6"
    }
  },
  "rewrites": [
    { "source": "/api/gaffer", "destination": "/api/gaffer" },
    { "source": "/api/commentary", "destination": "/api/commentary" },
    { "source": "/api/matches", "destination": "/api/matches" }
  ]
}
